<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".StartSessionActivity">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/sessionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sessionTitle"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/contactSelectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/trusted_contacts"
            android:textSize="16sp"
            android:textStyle="italic" />

        <Button
            android:id="@+id/selectContactsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/select_specific_contacts"
            android:onClick="onSelectTrustedContacts"
            android:textColor="@color/white"
            android:backgroundTint="@color/msu_green" />

        <Button
            android:id="@+id/selectAllContactsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/select_all_contacts"
            android:onClick="onSelectAllContacts"
            android:textColor="@color/white"
            android:backgroundTint="@color/msu_green" />

        <TextView
            android:id="@+id/selectedContactsSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/all_contacts_will_be_notified"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/destinationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/finalDest"
            android:textSize="16sp"
            android:textStyle="italic" />

        <EditText
            android:id="@+id/destinationInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:autofillHints="location"
            android:minHeight="48dp"
            android:textSize="18sp"
            android:hint="@string/destinationHint"
            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"
            android:inputType="none" />

        <Button
            android:id="@+id/startWalkingButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/sessionTitle"
            android:textSize="18sp"
            android:onClick="onStartSession"
            android:textColor="@color/white"
            android:backgroundTint="@color/msu_green"/>

        <TextView
            android:id="@+id/goBackFromSession"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:onClick="onGoBack"
            android:text="@string/GoBack"
            android:textSize="16sp" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/loginLogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="48dp"
            android:contentDescription="@string/msu_companion_logo"
            android:src="@drawable/msucompanionlogo" />

    </FrameLayout>
</LinearLayout>

