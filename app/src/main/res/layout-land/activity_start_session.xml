<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".StartSessionActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="658dp" />

    <TextView
        android:id="@+id/sessionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="@string/sessionTitle"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <TextView
        android:id="@+id/contactSelectionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/trusted_contacts"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/sessionTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/selectContactsButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/select_specific_contacts"
        android:onClick="onSelectTrustedContacts"
        android:textColor="@color/white"
        android:backgroundTint="@color/msu_green"
        app:layout_constraintTop_toBottomOf="@id/contactSelectionLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <Button
        android:id="@+id/selectAllContactsButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/select_all_contacts"
        android:onClick="onSelectAllContacts"
        android:textColor="@color/white"
        android:backgroundTint="@color/msu_green"
        app:layout_constraintTop_toBottomOf="@id/selectContactsButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <TextView
        android:id="@+id/selectedContactsSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_horizontal"
        android:text="@string/all_contacts_will_be_notified"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/selectAllContactsButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <TextView
        android:id="@+id/destinationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/finalDest"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/selectedContactsSummary"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/destinationInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:autofillHints="location"
        android:clickable="true"
        android:cursorVisible="false"
        android:focusable="false"
        android:hint="@string/destinationHint"
        android:inputType="none"
        android:minHeight="48dp"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/destinationLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <Button
        android:id="@+id/startWalkingButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/sessionTitle"
        android:textSize="18sp"
        android:onClick="onStartSession"
        android:textColor="@color/white"
        android:backgroundTint="@color/msu_green"
        app:layout_constraintTop_toBottomOf="@id/destinationInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <TextView
        android:id="@+id/goBackFromSession"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="48dp"
        android:onClick="onGoBack"
        android:text="@string/GoBack"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/startWalkingButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

</androidx.constraintlayout.widget.ConstraintLayout>